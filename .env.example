APP_ENV=development
APP_SERVER__HOST=127.0.0.1
APP_SERVER__PORT=8000
APP_DATABASE__URL=postgres://postgres:postgres@localhost:5432/ragent
APP_DATABASE__MAX_CONNECTIONS=10
APP_REDIS__URL=redis://127.0.0.1:6379
APP_REDIS__MAX_CONNECTIONS=5
APP_JWT__SECRET=change-me-to-a-random-256-bit-key
APP_JWT__ACCESS_TOKEN_EXPIRY_SECS=900
APP_JWT__REFRESH_TOKEN_EXPIRY_SECS=604800
APP_OLLAMA__BASE_URL=http://localhost:11434
APP_OLLAMA__MODEL=llama3
APP_OLLAMA__EMBEDDING_MODEL=nomic-embed-text
